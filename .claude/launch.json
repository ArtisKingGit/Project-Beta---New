{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "agrofast-backend",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["backend/main.py"],
      "port": 5500
    },
    {
      "name": "agrofast-desktop",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "offline_build", "start"],
      "port": 5500
    },
    {
      "name": "frontend-static",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8123", "--directory", "frontend"],
      "port": 8123
    }
  ]
}
